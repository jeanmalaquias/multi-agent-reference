# Per-agent provider selection (ADR-003). Defaults to the offline mock provider.
# Switch any agent to a real provider once its adapter is implemented:
#   mock | anthropic | bedrock | azure_foundry | vertex
MAGENT_PLANNER_PROVIDER=mock
MAGENT_RESEARCHER_PROVIDER=mock
MAGENT_WRITER_PROVIDER=mock
MAGENT_CRITIC_PROVIDER=mock

MAGENT_MAX_REVISIONS=3

# --- Real provider credentials (uncomment when wiring adapters) ---
# ANTHROPIC_API_KEY=
# AWS_REGION=us-east-1
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# GOOGLE_CLOUD_PROJECT=
